# --- DEPENDENCIAS ---
# Ignorar las carpetas de dependencias descargadas de npm/bun
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- CARPETAS DE COMPILACIÓN Y PRODUCCIÓN ---
# Ignorar los archivos generados automáticamente por Next.js al compilar
.next/
out/
build/
dist/

# --- ARCHIVOS DE CONFIGURACIÓN LOCAL / SECRETOS ---
# IMPORTANTE: Nunca subir las variables de entorno para no exponer contraseñas o tokens
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# --- CONFIGURACIÓN DE EDITORES E IDEs ---
# Ignorar archivos del editor de código
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- ARCHIVOS DE SISTEMA OPERATIVO ---
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows (Muy útil en tu sistema actual)
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini

# --- ARCHIVOS DE REGISTRO / DEBUG ---
# Archivos de registro que se generan cuando ocurre un error
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- CONFIGURACIONES DE VERCEL ---
# Ignorar configuraciones locales generadas por la herramienta CLI de Vercel
.vercel

# --- TYPESCRIPT ---
*.tsbuildinfo
next-env.d.ts

